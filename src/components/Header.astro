---
const pathname = Astro.url.pathname;
---

<header class="site-header" slot="header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="Vigilon Cyber home">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect width="28" height="28" rx="6" fill="#00D4FF"/>
        <path d="M14 5L6 9v6c0 5.25 3.4 10.15 8 11.35C18.6 25.15 22 20.25 22 15V9l-8-4z" fill="#0B1F3F" opacity="0.95"/>
        <path d="M12.5 16.5l-2-2 1.4-1.4 0.6 0.6 3.6-3.6 1.4 1.4-5 5z" fill="#00D4FF"/>
      </svg>
      Vigilon <span>Cyber</span>
    </a>

    <button class="mobile-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    <nav>
      <ul class="nav-links">
        <li><a href="/" class={pathname === '/' ? 'active' : ''}>Home</a></li>
        <li><a href="/services" class={pathname.startsWith('/services') ? 'active' : ''}>Services</a></li>
        <li><a href="/pricing" class={pathname === '/pricing' ? 'active' : ''}>Pricing</a></li>
        <li><a href="/blog" class={pathname.startsWith('/blog') ? 'active' : ''}>Blog</a></li>
        <li><a href="/faq" class={pathname === '/faq' ? 'active' : ''}>FAQ</a></li>
        <li><a href="/request-quote" class="nav-cta">Get a Quote</a></li>
      </ul>
    </nav>
  </div>
</header>
