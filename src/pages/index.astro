---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Vigilon Cyber | Cybersecurity Compliance & CE Marking Experts';
const description = 'Vigilon Cyber delivers expert cybersecurity compliance testing for CE marking to EN 18031-1, RED self-declaration, Notified Body preparation, ETSI IoT security, the Cyber Resilience Act, penetration testing and risk assessments.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>Cybersecurity Compliance You Can Trust</h1>
      <p>From technical assessments and penetration testing, to threat modelling and vulnerability scanning — we help manufacturers prove their products are secure, compliant, and market-ready. 
      </p>
      <div class="hero-actions">
        <a href="/request-quote" class="btn btn-primary btn-lg">Request a Quote</a>
        <a href="/services" class="btn btn-outline btn-lg">Our Services</a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="section-alt">
    <div class="container">
      <div class="trust-bar">
        <div class="trust-item">
          <div class="number" style="color:var(--color-accent);"></div>250+</div>
          <div class="label">Assessments Completed</div>
        </div>
        <div class="trust-item">
          <div class="number" style="color:var(--color-intelligent-blue);">5000+</div>
          <div class="label">Hours of Testing</div>
        </div>
        <div class="trust-item">
          <div class="number" style="color:var(--color-cta);">100%</div>
          <div class="label">Customer Retention</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Our Core Services</h2>
        <p>End-to-end cybersecurity compliance solutions for connected products entering the European market.</p>
      </div>
      <div class="grid grid-3">
        <a href="/services/red-cyber-compliance" class="card card-with-icon" style="text-decoration:none;color:inherit;">
          <div class="icon-box">
            <img src="/icons/conformity.svg" alt="" />
          </div>
          <h3>RED Cyber CE Mark Testing</h3>
          <p>Full compliance testing against EN&nbsp;18031 for conformity to RED DA Article 3.3 (d/e/f) now required for CE marking.</p>
        </a>
        <a href="/services/cyber-resilience-act" class="card card-with-icon" style="text-decoration:none;color:inherit;">
          <div class="icon-box secondary">
            <img src="/icons/shield.svg" alt="" />
          </div>
          <h3>Cyber Resilience Act Prep</h3>
          <p>Prepare your products for the EU Cyber Resilience Act requirements coming in 2027, including vulnerability handling, SBOM management, and ongoing obligations.</p>
        </a>
        <a href="/services/etsi-iot-security" class="card card-with-icon" style="text-decoration:none;color:inherit;">
          <div class="icon-box">
            <img src="/icons/network.svg" alt="" />
          </div>
          <h3>ETSI IoT Security</h3>
          <p>Assessment against ETSI EN&nbsp;303&nbsp;645 — the baseline cybersecurity standard for consumer IoT devices entering the European market.</p>
        </a>
        <a href="/services/penetration-testing" class="card card-with-icon" style="text-decoration:none;color:inherit;">
          <div class="icon-box cta">
            <img src="/icons/target.svg" alt="" />
          </div>
          <h3>Penetration Testing</h3>
          <p>Regular penetration tests across web applications, APIs, mobile apps, IoT devices and cloud infrastructure to uncover exploitable vulnerabilities.</p>
        </a>
        <a href="/services/risk-assessment" class="card card-with-icon" style="text-decoration:none;color:inherit;">
          <div class="icon-box secondary">
            <img src="/icons/chart.svg" alt="" />
          </div>
          <h3>Risk Assessment &amp; Threat Modelling</h3>
          <p>Structured risk assessments and threat modelling to identify, prioritise and mitigate security risks before they become compliance blockers.</p>
        </a>
        <a href="/services/vulnerability-scanning" class="card card-with-icon" style="text-decoration:none;color:inherit;background:var(--color-surface);">
          <div class="icon-box">
            <img src="/icons/search.svg" alt="" />
          </div>
          <h3>Vulnerability Scanning</h3>
          <p>Automated and manual vulnerability scanning services to continuously monitor your attack surface and maintain your security posture.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Vigilon -->
  <section class="section section-dark">
    <div class="container">
      <div class="section-header">
        <h2>Why Choose Vigilon Cyber?</h2>
        <p style="color:var(--color-accent-light);">We specialise exclusively in cybersecurity compliance for products entering new markets — it's all we do. Our clients stick with Vigilon because if your product
          doesn't pass the first time, we will continue to provide expert guidance, remediation support and re-tests until the your product is market ready. 
        </p>
      </div>
      <div class="grid grid-3">
        <div style="text-align:center;">
          <div class="feature-icon" style="margin:0 auto 1rem;">
            <img src="/icons/document.svg" alt="" style="width:1.75rem;height:1.75rem;" />
          </div>
          <h3 style="color:var(--color-accent-light);margin-bottom:0.75rem;">Regulatory Expertise</h3>
          <p style="color:var(--color-surface-alt);">Deep knowledge of the Radio Equipment Directive, EN&nbsp;18031 series, NIST Special Publication 800 Series, and ETSI "CYBER" Standards including EN&nbsp;303&nbsp;645 &amp; TS&nbsp;103&nbsp;701. We stay ahead of evolving requirements so you don't have to.</p>
        </div>
        <div style="text-align:center;">
          <div class="feature-icon" style="margin:0 auto 1rem;">
            <img src="/icons/users.svg" alt="" style="width:1.75rem;height:1.75rem;" />
          </div>
          <h3 style="color:var(--color-accent-light);margin-bottom:0.75rem;">Dual-Path Support</h3>
          <p style="color:var(--color-surface-alt);">Whether you're pursuing self-declaration or preparing for a Notified Body assessment, we tailor our approach to your compliance pathway.</p>
        </div>
        <div style="text-align:center;">
          <div class="feature-icon" style="margin:0 auto 1rem;">
            <img src="/icons/check-circle.svg" alt="" style="width:1.75rem;height:1.75rem;" />
          </div>
          <h3 style="color:var(--color-accent-light);margin-bottom:0.75rem;">Actionable Reporting</h3>
          <p style="color:var(--color-surface-alt);">Our reports don't just list findings — they provide clear remediation guidance prioritised by risk, so your engineering team can act fast.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container text-center">
      <h2>Ready to Achieve Compliance?</h2>
      <p style="max-width:580px;margin:1rem auto 2rem;color:var(--color-text-light);">Get in touch for a no-obligation consultation. We'll assess your product, outline the compliance pathway, and provide a clear quote.</p>
      <a href="/request-quote" class="btn btn-primary btn-lg">Request a Quote</a>
    </div>
  </section>

  <!-- Latest Blog -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Latest Insights</h2>
        <p>Expert articles on cybersecurity regulation, compliance strategy, and technical guidance.</p>
      </div>
      <div class="grid grid-3">
        <a href="/blog/en-18031-complete-guide" class="blog-card">
          <div class="card">
            <div class="blog-meta">April 2026 · 12 min read</div>
            <h3>The Complete Guide to EN 18031-1 Compliance</h3>
            <p>Everything manufacturers need to know about meeting EN&nbsp;18031-1 requirements for CE marking under the Radio Equipment Directive.</p>
            <span class="blog-tag">EN 18031</span>
          </div>
        </a>
        <a href="/blog/red-compliance-2026" class="blog-card">
          <div class="card">
            <div class="blog-meta">March 2026 · 8 min read</div>
            <h3>Radio Equipment Directive: Cybersecurity Requirements Explained</h3>
            <p>A practical breakdown of RED cybersecurity obligations and how to demonstrate conformity in 2026.</p>
            <span class="blog-tag">RED</span>
          </div>
        </a>
        <a href="/blog/cyber-resilience-act-overview" class="blog-card">
          <div class="card">
            <div class="blog-meta">February 2026 · 10 min read</div>
            <h3>Cyber Resilience Act: What Manufacturers Need to Know</h3>
            <p>An overview of the EU Cyber Resilience Act, its scope, timelines, and what it means for your product development lifecycle.</p>
            <span class="blog-tag">CRA</span>
          </div>
        </a>
      </div>
      <div class="text-center mt-2">
        <a href="/blog" class="btn btn-outline">View All Articles</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
