---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Cybersecurity Compliance Services | Vigilon Cyber';
const description = 'Comprehensive cybersecurity compliance services including EN 18031 testing, CE marking, Cyber Resilience Act readiness, ETSI IoT security, penetration testing, risk assessments and vulnerability scanning.';

const services = [
  {
    title: 'EN 18031-1 Compliance Testing',
    href: '/services/en-18031-compliance',
    description: 'Full compliance testing and gap analysis against EN 18031-1 for CE marking under the Radio Equipment Directive. We support both self-declaration and Notified Body assessment pathways.',
    tags: ['CE Marking', 'RED', 'EN 18031'],
  },
  {
    title: 'Cyber Resilience Act Readiness',
    href: '/services/cyber-resilience-act',
    description: 'Prepare your products and processes for the EU Cyber Resilience Act. We cover gap analysis, vulnerability handling procedures, SBOM management and conformity assessment preparation.',
    tags: ['CRA', 'EU Regulation'],
  },
  {
    title: 'ETSI EN 303 645 — IoT Security',
    href: '/services/etsi-iot-security',
    description: 'Assessment and testing against the ETSI EN 303 645 baseline cybersecurity standard for consumer IoT devices, including the associated test specification ETSI TS 103 701.',
    tags: ['IoT', 'ETSI', 'Consumer Devices'],
  },
  {
    title: 'Penetration Testing',
    href: '/services/penetration-testing',
    description: 'Regular penetration testing across web applications, APIs, mobile apps, IoT devices and cloud infrastructure. We follow OWASP, PTES and OSSTMM methodologies.',
    tags: ['Web', 'API', 'IoT', 'Cloud'],
  },
  {
    title: 'Risk Assessment & Threat Modelling',
    href: '/services/risk-assessment',
    description: 'Systematic risk assessments and threat modelling using STRIDE, DREAD and attack-tree methodologies to identify, prioritise and mitigate security risks across your product ecosystem.',
    tags: ['STRIDE', 'Risk', 'Threat Model'],
  },
  {
    title: 'Vulnerability Scanning',
    href: '/services/risk-assessment',
    description: 'Continuous automated and manual vulnerability scanning services to monitor your external attack surface, internal networks and cloud environments.',
    tags: ['Continuous', 'Automated', 'Monitoring'],
  },
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <section class="page-header">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a><span>/</span><strong>Services</strong>
      </div>
      <h1>Our Services</h1>
      <p>End-to-end cybersecurity compliance and security testing services for connected products and digital infrastructure.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2">
        {services.map(service => (
          <a href={service.href} class="card" style="text-decoration:none;color:inherit;">
            <h2 style="font-size:1.35rem;margin-bottom:0.75rem;">{service.title}</h2>
            <p style="color:var(--color-text-light);margin-bottom:1rem;">{service.description}</p>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
              {service.tags.map(tag => (
                <span class="blog-tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container text-center">
      <h2>Not Sure What You Need?</h2>
      <p style="color:var(--color-accent-light);max-width:560px;margin:1rem auto 2rem;">Book a free 30-minute consultation and we'll help you identify the right compliance pathway for your product.</p>
      <a href="/request-quote" class="btn btn-white btn-lg">Request a Quote</a>
    </div>
  </section>

  <Footer />
</BaseLayout>
