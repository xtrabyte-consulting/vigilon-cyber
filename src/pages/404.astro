---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Page Not Found | Vigilon Cyber';
const description = 'The page you are looking for could not be found.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <section class="section" style="min-height:50vh;display:flex;align-items:center;">
    <div class="container text-center">
      <h1 style="font-size:6rem;color:var(--color-accent);margin-bottom:0;">404</h1>
      <h2>Page Not Found</h2>
      <p style="color:var(--color-text-light);margin:1rem auto 2rem;max-width:480px;">The page you're looking for doesn't exist or has been moved. Try navigating back to our homepage or browsing our services.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/services" class="btn btn-outline">Our Services</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
