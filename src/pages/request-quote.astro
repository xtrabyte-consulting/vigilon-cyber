---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Request a Quote — Cybersecurity Compliance Testing | Vigilon Cyber';
const description = 'Request a no-obligation quote for EN 18031 compliance testing, Cyber Resilience Act readiness, ETSI IoT security, penetration testing, risk assessments or vulnerability scanning from Vigilon Cyber.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <section class="page-header">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a><span>/</span><strong>Request a Quote</strong>
      </div>
      <h1>Request a Quote</h1>
      <p>Tell us about your product and compliance needs. We'll respond with a detailed, no-obligation quote within 24 hours.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:720px;">
      <div class="grid grid-2" style="margin-bottom:3rem;">
        <div>
          <h2 style="font-size:1.35rem;margin-bottom:0.75rem;">What happens next?</h2>
          <ol style="padding-left:1.25rem;color:var(--color-text-light);line-height:2;">
            <li>Submit your details below</li>
            <li>We schedule a free 30-minute consultation</li>
            <li>We assess your requirements and scope</li>
            <li>You receive a detailed quote within 24 hours</li>
          </ol>
        </div>
        <div>
          <h2 style="font-size:1.35rem;margin-bottom:0.75rem;">Contact us directly</h2>
          <p style="color:var(--color-text-light);">
            <strong>Email:</strong> <a href="mailto:info@vigiloncyber.com">info@vigiloncyber.com</a><br/>
            <strong>Phone:</strong> <a href="tel:+44XXXXXXXXXX">+44 XXXX XXXXXX</a><br/>
            <strong>Hours:</strong> Mon–Fri 09:00–17:30 GMT
          </p>
        </div>
      </div>

      <form name="quote-request" method="POST" data-netlify="true" action="/request-quote?success=true">
        <div class="grid grid-2">
          <div class="form-group">
            <label for="firstName">First Name *</label>
            <input type="text" id="firstName" name="firstName" required autocomplete="given-name" />
          </div>
          <div class="form-group">
            <label for="lastName">Last Name *</label>
            <input type="text" id="lastName" name="lastName" required autocomplete="family-name" />
          </div>
        </div>

        <div class="grid grid-2">
          <div class="form-group">
            <label for="email">Work Email *</label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" />
          </div>
        </div>

        <div class="grid grid-2">
          <div class="form-group">
            <label for="company">Company Name *</label>
            <input type="text" id="company" name="company" required autocomplete="organization" />
          </div>
          <div class="form-group">
            <label for="jobTitle">Job Title</label>
            <input type="text" id="jobTitle" name="jobTitle" autocomplete="organization-title" />
          </div>
        </div>

        <div class="form-group">
          <label for="service">Which service(s) are you interested in? *</label>
          <select id="service" name="service" required>
            <option value="">Select a service</option>
            <option value="en-18031">EN 18031-1 Compliance Testing</option>
            <option value="cra">Cyber Resilience Act Readiness</option>
            <option value="etsi">ETSI EN 303 645 IoT Security</option>
            <option value="pentest">Penetration Testing</option>
            <option value="risk">Risk Assessment & Threat Modelling</option>
            <option value="vuln-scan">Vulnerability Scanning</option>
            <option value="multiple">Multiple Services / Bundle</option>
            <option value="not-sure">Not Sure — Need Guidance</option>
          </select>
        </div>

        <div class="form-group">
          <label for="productDescription">Tell us about your product *</label>
          <textarea id="productDescription" name="productDescription" required placeholder="Briefly describe your product, its connectivity (Wi-Fi, Bluetooth, cellular, etc.), target market, and where you are in the development lifecycle."></textarea>
        </div>

        <div class="form-group">
          <label for="compliancePath">Preferred compliance pathway</label>
          <select id="compliancePath" name="compliancePath">
            <option value="">Select if applicable</option>
            <option value="self-declaration">Self-declaration (Module A)</option>
            <option value="notified-body">Notified Body assessment (Module B+C)</option>
            <option value="not-sure">Not sure — need guidance</option>
          </select>
        </div>

        <div class="form-group">
          <label for="timeline">Target timeline</label>
          <select id="timeline" name="timeline">
            <option value="">Select a timeline</option>
            <option value="urgent">Urgent — within 4 weeks</option>
            <option value="standard">Standard — 1–3 months</option>
            <option value="planning">Planning — 3–6 months</option>
            <option value="future">Future — 6+ months</option>
          </select>
        </div>

        <div class="form-group">
          <label for="additionalInfo">Additional information</label>
          <textarea id="additionalInfo" name="additionalInfo" placeholder="Any other details that would help us scope your engagement — e.g., number of products, existing certifications, specific regulatory concerns."></textarea>
        </div>

        <!-- Honeypot field for bot prevention -->
        <div style="display:none;" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;">
          Submit Quote Request
        </button>

        <p style="text-align:center;margin-top:1rem;font-size:0.875rem;color:var(--color-text-light);">
          By submitting this form, you agree to our privacy policy. We will never share your information with third parties.
        </p>
      </form>
    </div>
  </section>

  <Footer />
</BaseLayout>
